# ============================================================
# MedConsult AI — Environment Variables Template
# Sao chép file này thành .env và điền các giá trị thực
# ============================================================

# ----------------------------
# Google Gemini API (BẮT BUỘC)
# Lấy tại: https://aistudio.google.com/app/apikey
# ----------------------------
GOOGLE_API_KEY=your_google_api_key_here

# Model LLM (text + vision)
LLM_MODEL=gemini-2.5-flash-lite

# Model embedding (768-dim vectors)
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# ----------------------------
# PostgreSQL (BẮT BUỘC)
# Chạy local: postgresql://postgres:postgres@localhost:5432/medical_db
# ----------------------------
POSTGRES_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/medical_db

# ----------------------------
# Qdrant Vector DB (BẮT BUỘC)
# Docker: docker run -p 6333:6333 qdrant/qdrant
# ----------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=medical_docs

# ----------------------------
# JWT Authentication (BẮT BUỘC)
# Tạo JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------
JWT_SECRET_KEY=your_64_char_hex_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------
# Weather API (tùy chọn — cho tính năng cảnh báo sức khỏe theo thời tiết)
# Đăng ký miễn phí tại: https://www.weatherapi.com/
# ----------------------------
WEATHER_API_KEY=your_weatherapi_key_here
WEATHER_API_URL=https://api.weatherapi.com/v1/current.json
WEATHER_CACHE_SECONDS=300

# ----------------------------
# Cấu hình ứng dụng
# ----------------------------
APP_NAME=Medical RAG
DEBUG=false

# ----------------------------
# Hệ thống điểm / Wallet
# POINT_VALUE_VND: 1 điểm = N VND
# MIN_POINTS_TO_CHAT: số điểm tối thiểu cần có để gửi tin nhắn
# DAILY_CHECKIN_REWARD: điểm thưởng khi điểm danh mỗi ngày
# ----------------------------
POINT_VALUE_VND=100
DAILY_CHECKIN_REWARD=50
MIN_POINTS_TO_CHAT=20

# ----------------------------
# Gemini Pricing (dùng để tính chi phí token → VND)
# Đơn vị: USD per 1 million tokens
# ----------------------------
GEMINI_INPUT_PRICE_USD=0.075
GEMINI_OUTPUT_PRICE_USD=0.30
USD_TO_VND_RATE=25000
